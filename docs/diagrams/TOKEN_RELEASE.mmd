    Reflow --> |"30%"| I["邀请激励基金<br/>好友活跃"]
    Reflow --> |"20%"| C["社区基金<br/>平台运营/DAO"]

    S --> S1["每日分配"]
    I --> I1["持续激励"]
    C --> C1["生态发展"]

    style Burn fill:#FF6B6B
    style Reflow fill:#90EE90
    style S fill:#87CEEB
    style I fill:#FFD700
    style C fill:#DDA0DD
```

